    {
      "name": "checkAuth",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "const response = pm.response.json();\r",
              "pm.test(\"Response contains Viewer data\", function () {\r",
              "    pm.expect(response.data).to.have.property(\"Viewer\");\r",
              "    pm.expect(response.data.Viewer).to.have.property(\"id\");\r",
              "    pm.expect(response.data.Viewer).to.have.property(\"name\");\r",
              "});\r",
              "if (response.data && response.data.Viewer) {\r",
              "    pm.environment.set(\"user_id\", response.data.Viewer.id);\r",
              "    console.log(\"Authenticated as: \" + response.data.Viewer.name);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"query\": \"query { Viewer { id name avatar { large } statistics { anime { count } } } }\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}",
          "host": [
            "{{base_url}}"
          ]
        }
      },
      "response": []
    },
