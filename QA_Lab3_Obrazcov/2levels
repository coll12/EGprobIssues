#include <iostream>
#include <cmath>
#include "small_number.h"

void SmallNumber::Init(int d1, int d2, int d3) {
    this->digit1 = (d1 >= 0 && d1 <= 9) ? d1 : 0;
    this->digit2 = (d2 >= 0 && d2 <= 9) ? d2 : 0;
    this->digit3 = (d3 >= 0 && d3 <= 9) ? d3 : 0;
}

void SmallNumber::Read() {
    int d1, d2, d3;
    std::cout << "Введите первую цифру (0-9): ";
    std::cin >> d1;
    std::cout << "Введите вторую цифру (0-9): ";
    std::cin >> d2;
    std::cout << "Введите третью цифру (0-9): ";
    std::cin >> d3;
    this->Init(d1, d2, d3);
}

void SmallNumber::Display() {
    std::cout << "Число: " << this->toInt() << std::endl;
}

int SmallNumber::toInt() const {
    return this->digit1 * 100 + this->digit2 * 10 + this->digit3;
}

SmallNumber SmallNumber::Add(const SmallNumber& other) const {
    int sum = this->toInt() + other.toInt();
    SmallNumber result;

    if (sum >= 1000) {
        result.Init(0, 0, 0);
    }
    else {
        result.Init(sum / 100, (sum % 100) / 10, sum % 10);
    }
    return result;
}

SmallNumber SmallNumber::Add(int num) const {
    int sum = this->toInt() + num;
    SmallNumber result;

    if (sum >= 1000) {
        result.Init(0, 0, 0);
    }
    else {
        result.Init(sum / 100, (sum % 100) / 10, sum % 10);
    }
    return result;
}

SmallNumber add(SmallNumber a, SmallNumber b) {
    SmallNumber result;
    int sum = a.toInt() + b.toInt();

    if (sum >= 1000) {
        result.Init(0, 0, 0);
    }
    else {
        result.Init(sum / 100, (sum % 100) / 10, sum % 10);
    }
    return result;
}

SmallNumber createFromInt(int value) {
    SmallNumber result;
    if (value >= 0 && value < 1000) {
        result.Init(value / 100, (value % 100) / 10, value % 10);
    }
    else {
        result.Init(0, 0, 0);
    }
    return result;
}
