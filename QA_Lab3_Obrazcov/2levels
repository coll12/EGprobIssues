#pragma once
#ifndef HEADERS_SMALL_NUMBER_H_
#define HEADERS_SMALL_NUMBER_H_

class SmallNumber {
public:
    void Init(int d1, int d2, int d3);
    void Read();
    void Display();
    int toInt() const;
    SmallNumber Add(const SmallNumber& other) const;
    SmallNumber Add(int num) const;

private:
    int digit1;
    int digit2;
    int digit3;
};

SmallNumber add(SmallNumber a, SmallNumber b);
SmallNumber createFromInt(int value);

#endif
Main.h
#include <iostream>
#include "small_number.h"

int main() {
    setlocale(LC_ALL, "RUS");

    SmallNumber a;
    std::cout << "Введите первое число:" << std::endl;
    a.Read();
    a.Display();

    SmallNumber b;
    std::cout << "Введите второе число:" << std::endl;
    b.Read();
    b.Display();

    SmallNumber c = add(a, b);
    std::cout << "Результат сложения: " << c.toInt() << std::endl;

    SmallNumber d = a.Add(b);
    std::cout << "Результат метода Add с другим объектом: " << d.toInt() << std::endl;

    SmallNumber e = a.Add(50);
    std::cout << "Результат метода Add с числом 50: " << e.toInt() << std::endl;

    SmallNumber test = createFromInt(123);
    std::cout << "Тестовое число из 123: " << test.toInt() << std::endl;

    SmallNumber* dynamicObj = new SmallNumber;
    std::cout << "Введите число:" << std::endl;
    dynamicObj->Read();

    dynamicObj->Display();
    (*dynamicObj).Display();

    delete dynamicObj;

    int arraySize;
    std::cout << "Введите размер массива: ";
    std::cin >> arraySize;

    SmallNumber* numberArray = new SmallNumber[arraySize];

    for (int i = 0; i < arraySize; i++) {
        std::cout << "Введите число для элемента " << i + 1 << ":" << std::endl;
        numberArray[i].Read();
    }

    std::cout << "Содержимое массива:" << std::endl;
    for (int i = 0; i < arraySize; i++) {
        std::cout << numberArray[i].toInt() << std::endl;
    }

    delete[] numberArray;

    return 0;
}
 
